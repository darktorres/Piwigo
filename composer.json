{
    "minimum-stability": "beta",
    "prefer-stable": true,
    "require": {
        "php": "^8.3",
        "ahand/mobileesp": "dev-master",
        "cweagans/composer-patches": "^2.0",
        "jcupitt/vips": "dev-master",
        "katzgrau/klogger": "^1.2",
        "openpsa/universalfeedcreator": "^v1.8.4.1",
        "pclzip/pclzip": "^2.8",
        "pelago/emogrifier": "^7.0",
        "phpmailer/phpmailer": "^6.7",
        "smarty/smarty": "^5.2",
        "tedivm/jshrink": "^1.4",
        "tubalmartin/cssmin": "^4.1"
    },
    "config": {
        "allow-plugins": {
            "cweagans/composer-patches": true
        },
        "optimize-autoloader": true
    },
    "extra": {
        "patches": {
            "smarty/smarty": {
                "Patch strftime": "patches/strftime.patch"
            }
        }
    },
    "require-dev": {
        "symplify/easy-coding-standard": "^12.2",
        "rector/rector": "^1.1",
        "vimeo/psalm": "^5.24",
        "phpstan/phpstan": "^1.11"
    },
    "autoload": {
        "psr-4": {
            "Piwigo\\": ""
        }
    }
}
